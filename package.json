{
  "name": "semantic-dapp",
  "version": "0.1.0-beta",
  "private": true,
  "type": "module",
  "description": "Generate usable user dApps and admin consoles from EVM contract ABI, NatSpec and source code.",
  "keywords": [
    "ethereum",
    "evm",
    "smart-contracts",
    "abi",
    "dapp",
    "web3",
    "wallet",
    "viem",
    "wagmi",
    "solidity",
    "erc20",
    "erc721",
    "erc4626",
    "accesscontrol",
    "admin-panel",
    "code-generation",
    "developer-tools",
    "typescript",
    "self-hostable",
    "open-source"
  ],
  "homepage": "https://github.com/TacitvsXI/semantic-dapp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TacitvsXI/semantic-dapp.git"
  },
  "bugs": {
    "url": "https://github.com/TacitvsXI/semantic-dapp/issues"
  },
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "gen:abi": "node scripts/gen-abi.mjs",
    "gen:demos": "node scripts/gen-demos.mjs",
    "gen:pages": "node scripts/gen-pages-bundle.mjs",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@semantic-dapp/classifier": "workspace:*",
    "@semantic-dapp/export": "workspace:*",
    "@semantic-dapp/spec": "workspace:*",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "axios@>=1.0.0 <1.18.0": ">=1.18.0",
      "ws@>=8.0.0 <8.21.0": ">=8.21.0",
      "uuid@<11.1.1": ">=11.1.1"
    }
  }
}
