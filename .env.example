# Copy to .env.local for local development. Never commit real secrets.

# Default RPC used by the studio (can be overridden in the UI).
# For local development against Anvil:
VITE_DEFAULT_RPC_URL=http://127.0.0.1:8545
VITE_DEFAULT_CHAIN_ID=31337

# Optional: WalletConnect Cloud project id (https://cloud.reown.com).
# Leave empty to use injected wallets only (MetaMask/Rabby) — enough for local
# dev. Set it to enable the full RainbowKit wallet list (WalletConnect QR, etc).
VITE_WALLETCONNECT_PROJECT_ID=
